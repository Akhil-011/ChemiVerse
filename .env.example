# ============================================================
# ChemiVerse — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# App
VITE_APP_NAME=ChemiVerse
VITE_APP_URL=http://localhost:5173

# Backend API (Node.js + Express)
VITE_API_URL=http://localhost:3001/api

# AI Services (replace mocked responses)
VITE_OPENAI_API_KEY=sk-your-openai-key-here
VITE_GEMINI_API_KEY=your-gemini-key-here
VITE_ANTHROPIC_API_KEY=your-anthropic-key-here

# Database (MongoDB)
VITE_MONGODB_URI=mongodb://localhost:27017/chemfusion
VITE_MONGODB_DB=chemfusion

# Supabase (if migrating to Supabase backend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Chemistry APIs
VITE_PUBCHEM_API_URL=https://pubchem.ncbi.nlm.nih.gov/rest/pug
VITE_CHEMSPIDER_KEY=your-chemspider-key

# Feature Flags
VITE_ENABLE_VOICE=true
VITE_ENABLE_AI_TUTOR=true
VITE_ENABLE_ANALYTICS=false
